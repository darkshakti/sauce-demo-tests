{
  "name": "sauce-demo-e2e",
  "version": "1.0.0",
  "description": "E2E test automation framework for SauceDemo (saucedemo.com) built with Playwright + TypeScript. Page Object Model, multi-browser, CI/CD, Allure reporting.",
  "type": "module",
  "scripts": {
    "postinstall": "playwright install",
    "test": "playwright test --project=chromium",
    "test:all": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:smoke": "playwright test --project=smoke",
    "test:regression": "playwright test --project=regression",
    "test:e2e": "playwright test tests/e2e",
    "test:api": "playwright test tests/api",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:headed": "playwright test --headed",
    "test:headed:chromium": "playwright test --project=chromium --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "codegen": "playwright codegen https://www.saucedemo.com",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e",
    "test-automation",
    "page-object-model",
    "allure",
    "saucedemo"
  ],
  "author": "Margarita Vladyko",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/node": "26.0.0",
    "allure-commandline": "2.43.0",
    "allure-playwright": "3.10.0",
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  }
}
